# Copy to .env and fill in. Everything is optional: with no keys the app runs
# in fully-local mode (deterministic NL-to-SQL + in-memory vector search).

# Execution mode: auto | cloud | local
IPDR_MODE=auto

# --- OpenAI (enables LLM NL-to-SQL, LLM routing, LLM narration) ---
OPENAI_API_KEY=
IPDR_ROUTER_MODEL=gpt-4o-mini
IPDR_SQL_MODEL=gpt-4o
IPDR_NARRATIVE_MODEL=gpt-4o

# --- Qdrant (enables managed vector search with server-side filtering) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ipdr_logs

# --- Embeddings ---
IPDR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Data ---
IPDR_DATA_PATH=data/rag_formatted_data.xlsx
